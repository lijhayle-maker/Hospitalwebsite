function renderPhysicianWorkspaceQueue() {
    const doctors = getDB("doctors");
    const patients = getDB("patients");

    const activeDoc = doctors.find(d => d.id === currentAuthenticatedDoctorId);
    if (!activeDoc) return;

    document.getElementById("doc-ui-id").innerText = activeDoc.id;
    document.getElementById("doc-ui-pin").innerText = activeDoc.pin;
    document.getElementById("doc-portal-title").innerText = `${activeDoc.name} | Clinic Workspace`;

    const personalWorkload = patients.filter(p => p.assignedConsultantId === activeDoc.id);
    const activeWorkload = personalWorkload.filter(p => !p.discharged);
    
    const performanceIncentivePay = personalWorkload.length * 250.00;
    document.getElementById("doc-ui-bonus").innerText = `$${performanceIncentivePay.toFixed(2)}`;
    document.getElementById("doc-ui-total").innerText = `$${(8500.00 + performanceIncentivePay).toFixed(2)}`;

    const tbody = document.getElementById("doc-queue-table-body");
    tbody.innerHTML = "";

    if (activeWorkload.length === 0) {
        tbody.innerHTML = `<tr><td colspan="6" class="text-center" style="color:var(--text-secondary); padding: 30px;">No active files in your queue track matrix.</td></tr>`;
        return;
    }

    activeWorkload.forEach(p => {
        const tr = document.createElement("tr");
        tr.innerHTML = `
            <td><span class="badge tag-${p.triageSeverityIndex}">${p.triageSeverityIndex}</span></td>
            <td><code>${p.id}</code></td>
            <td>
                <strong>${p.name}</strong> <small>(${p.age} Y/O)</small><br>
                <small style="color:var(--accent-blue); font-weight:600;">Room: ${p.allocatedRoom}</small>
            </td>
            <td>
                <div class="clinical-orders-cell">
                    <small>• ${p.clinicalInterventionsHistory.join("<br>• ")}</small>
                </div>
            </td>
            <td><strong class="text-green">$${p.financialAccountBalance.toFixed(2)}</strong></td>
            <td>
                <div class="action-btn-cell">
                    <button onclick="orderMedication('${p.id}')" class="btn-grid btn-rx">💊 Rx Package (+$350)</button>
                    <button onclick="scheduleSurgery('${p.id}')" class="btn-grid btn-or">🩻 Apply OR Track (+$1,200)</button>
                    <button onclick="dischargePatient('${p.id}')" class="btn-grid btn-disc">🔒 Discharge File & Settle</button>
                </div>
            </td>
        `;
        tbody.appendChild(tr);
    });
}

function orderMedication(pId) {
    const rx = prompt("Enter specific clinical prescription parameters:");
    if (!rx) return;
    mutatePatientRecord(pId, r => {
        r.clinicalInterventionsHistory.push(`Prescription Logged: ${rx}`);
        r.financialAccountBalance += 350.00;
    });
}

function scheduleSurgery(pId) {
    const or = prompt("Specify surgical tracking parameters:");
    if (!or) return;
    mutatePatientRecord(pId, r => {
        r.clinicalInterventionsHistory.push(`Surgical Event Scheduled: ${or}`);
        r.financialAccountBalance += 1200.00;
    });
}

function dischargePatient(pId) {
    if (!confirm("Authorize discharge closure? Total ledger invoice value will instantly liquidate into realized facility gross revenue reserves.")) return;
    mutatePatientRecord(pId, r => {
        r.discharged = true;
        r.clinicalInterventionsHistory.push("Clinical case closed. Account ledger balanced and liquidated.");
    });
}

function mutatePatientRecord(pId, balanceMutationCallback) {
    const patients = getDB("patients");
    const idx = patients.findIndex(p => p.id === pId);
    if (idx !== -1) {
        balanceMutationCallback(patients[idx]);
        saveDB("patients", patients);
        renderPhysicianWorkspaceQueue();
        refreshGlobalCapacityVisualizers();
    }
}

