function openGateway(type) {
    currentAuthType = type;
    const block = document.getElementById("auth-selector-block");
    block.innerHTML = "";
    document.getElementById("auth-pin").value = "";
    document.getElementById("auth-global-error").innerText = "";

    if (type === 'admin') {
        document.getElementById("auth-icon").innerText = "🛠️";
        document.getElementById("auth-title").innerText = "Executive Administration Gate";
        document.getElementById("auth-subtitle").innerText = "Enter root administrative master key signature. Default: 0000";
    } else {
        document.getElementById("auth-icon").innerText = "🩺";
        document.getElementById("auth-title").innerText = "Physician Diagnostics Portal";
        document.getElementById("auth-subtitle").innerText = "Verify credentials profile configuration details below.";
        
        const doctors = getDB("doctors");
        let selectHtml = `<label>Select Your Practitioner Profile</label>
                          <select id="auth-doc-id-select">`;
        doctors.forEach(d => {
            selectHtml += `<option value="${d.id}">${d.name} — [${d.specialty}] (${d.status})</option>`;
        });
        selectHtml += `</select>`;
        block.innerHTML = selectHtml;
    }
    switchView("auth-view");
}

function validateGatewayCredentials() {
    const pin = document.getElementById("auth-pin").value.trim();
    const err = document.getElementById("auth-global-error");
    err.innerText = "";

    if (!pin) {
        err.innerText = "Entry Required: Please insert access authorization passcode.";
        return;
    }

    if (currentAuthType === 'admin') {
        if (pin === ADMIN_SECURE_PIN) {
            switchView("admin-view");
        } else {
            err.innerText = "Access Violation: Authentication signature rejected.";
        }
    } else {
        const selectElement = document.getElementById("auth-doc-id-select");
        if (!selectElement) return;
        
        const docId = selectElement.value;
        const doctors = getDB("doctors");
        const match = doctors.find(d => d.id === docId);

        if (match) {
            if (match.status !== "Active") {
                err.innerText = `Access Denied: Profile lifecycle code is currently [${match.status}].`;
                return;
            }
            if (String(match.pin).trim() === String(pin)) {
                currentAuthenticatedDoctorId = match.id;
                switchView("doctor-view");
            } else {
                err.innerText = "Access Violation: Private portal token match failed.";
            }
        }
    }
}

function executeDoctorPINMutation() {
    const currentPinInput = prompt("Verify current security PIN code signature:");
    if (currentPinInput === null) return;

    const doctors = getDB("doctors");
    const idx = doctors.findIndex(d => d.id === currentAuthenticatedDoctorId);

    if (idx !== -1) {
        if (String(doctors[idx].pin).trim() !== String(currentPinInput).trim()) {
            alert("Verification Failed: Input token matching signature mismatch.");
            return;
        }

        const newPin = prompt("Establish new secure 4-digit token access PIN:");
        if (newPin === null) return;

        if (newPin.trim().length !== 4 || isNaN(newPin)) {
            alert("Configuration Aborted: Passcode must be exactly 4 digits.");
            return;
        }

        doctors[idx].pin = newPin.trim();
        saveDB("doctors", doctors);
        
        document.getElementById("doc-ui-pin").innerText = doctors[idx].pin;
        alert("Security Configuration Updated successfully.");
    }
}

// ==========================================
// REGULATED TREASURY & LIQUID ASSET MATRIX
// ==========================================
function processManualCashTransaction(e) {
    e.preventDefault();
    const type = document.getElementById("cash-type").value;
    const amount = parseFloat(document.getElementById("cash-amount").value);
    const note = document.getElementById("cash-note").value.trim() || "Manual Regulatory Adjustment";

    if (isNaN(amount) || amount <= 0) {
        alert("Please specify a valid monetary amount.");
        return;
    }

    const cashLedger = getDB("cash_ledger");
    cashLedger.push({
        type: type,
        amount: amount,
        note: note,
        date: new Date().toLocaleDateString()
    });
    saveDB("cash_ledger", cashLedger);

    document.getElementById("cash-regulation-form").reset();
    renderAdminDashboardLedgers();
    alert("Transaction logged directly to hospital cash flow matrix.");
}

function triggerPayrollPayout() {
    const doctors = getDB("doctors");
    const patients = getDB("patients");
    const cashLedger = getDB("cash_ledger");

    let calculatedPayrollOverhead = 0;
    doctors.forEach(d => {
        const cases = patients.filter(p => p.assignedConsultantId === d.id).length;
        calculatedPayrollOverhead += 8500.00 + (cases * 250.00);
    });

    cashLedger.push({
        type: "Out",
        amount: calculatedPayrollOverhead,
        note: "Disbursed Realized Live Staff Payroll Liabilities Asset Cycle",
        date: new Date().toLocaleDateString()
    });
    
    saveDB("cash_ledger", cashLedger);
    renderAdminDashboardLedgers();
    alert(`System Asset Disbursement Confirmed:\n$${calculatedPayrollOverhead.toFixed(2)} parsed out of reserve vaults.`);
}

function renderAdminDashboardLedgers() {
    const doctors = getDB("doctors");
    const patients = getDB("patients");
    const cashLedger = getDB("cash_ledger");

    // Realized Gross Revenue is strictly computed from realized, discharged entries
    let totalGrossFacilityRevenue = 0;
    patients.forEach(p => { 
        if (p.discharged) {
            totalGrossFacilityRevenue += p.financialAccountBalance; 
        }
    });

    let totalAccruedOverheadLiabilities = 0;
    doctors.forEach(d => {
        const cases = patients.filter(p => p.assignedConsultantId === d.id).length;
        totalAccruedOverheadLiabilities += 8500.00 + (cases * 250.00);
    });

    // Compute central vault cache via manual cash regulations + realized dynamic intake balances
    let totalCashIn = 0;
    let totalCashOut = 0;
    cashLedger.forEach(item => {
        if (item.type === "In") totalCashIn += item.amount;
        if (item.type === "Out") totalCashOut += item.amount;
    });

    const netTreasuryLiquidity = (totalCashIn + totalGrossFacilityRevenue) - totalCashOut;

    document.getElementById("t-revenue").innerText = `$${totalGrossFacilityRevenue.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
    document.getElementById("t-payroll").innerText = `$${totalAccruedOverheadLiabilities.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
    
    const reserveField = document.getElementById("t-net-reserve");
    reserveField.innerText = `$${netTreasuryLiquidity.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
    reserveField.className = netTreasuryLiquidity >= 0 ? "text-green" : "text-orange";

    // Rebuild Personnel Directory Rows
    const dBody = document.getElementById("admin-docs-table-body");
    dBody.innerHTML = "";
    doctors.forEach(d => {
        const tr = document.createElement("tr");
        tr.innerHTML = `
            <td><code>${d.id}</code></td>
            <td><strong>${d.name}</strong></td>
            <td>${d.specialty}</td>
            <td><code class="admin-pin-view-tag">🔑 ${d.pin}</code></td>
            <td><span class="status-indicator-tag status-${d.status.toLowerCase().replace(" ", "")}">${d.status}</span></td>
            <td class="no-print">
                <select onchange="updateDoctorLifecycleStatus('${d.id}', this.value)" class="lifecycle-select">
                    <option value="">-- Modify Status --</option>
                    <option value="Active">🟢 Active</option>
                    <option value="Suspended">💡 Suspend</option>
                    <option value="Fired">❌ Terminate Entry</option>
                </select>
            </td>
        `;
        dBody.appendChild(tr);
    });

    // Populate Patient Audit Matrix Rows
    const pBody = document.getElementById("admin-patients-table-body");
    pBody.innerHTML = "";
    patients.forEach(p => {
        const tr = document.createElement("tr");
        tr.innerHTML = `
            <td><code>${p.id}</code></td>
            <td><strong>${p.name}</strong></td>
            <td><small>Symptom: ${p.presentingSymptom}<br>Room: ${p.allocatedRoom}</small></td>
            <td><span class="badge tag-${p.triageSeverityIndex}">${p.triageSeverityIndex}</span></td>
            <td>${p.routedDepartment}</td>
            <td><span class="badge ${p.discharged ? 'tag-Green' : 'tag-Yellow'}">${p.discharged ? 'Discharged' : 'Admitted'}</span></td>
            <td><strong class="text-green">$${p.financialAccountBalance.toFixed(2)}</strong></td>
        `;
        pBody.appendChild(tr);
    });

    // Populate Cash Flow Regulation History Table
    const cBody = document.getElementById("admin-cash-table-body");
    cBody.innerHTML = "";
    [...cashLedger].reverse().forEach(item => {
        const tr = document.createElement("tr");
        tr.innerHTML = `
            <td>${item.date}</td>
            <td><span class="badge ${item.type === 'In' ? 'tag-Green' : 'tag-Red'}">Cash ${item.type}</span></td>
            <td><strong>$${item.amount.toFixed(2)}</strong></td>
            <td><span style="color:var(--text-secondary); font-size:0.8rem;">${item.note}</span></td>
        `;
        cBody.appendChild(tr);
    });
}

function processDoctorOnboardingAction(e) {
    e.preventDefault();
    const name = document.getElementById("adm-doc-name").value.trim();
    const spec = document.getElementById("adm-doc-specialty").value;
    const pin = document.getElementById("adm-doc-pin").value.trim();

    if (pin.length !== 4 || isNaN(pin)) {
        alert("Starter passcodes must meet 4-digit numeric conditions.");
        return;
    }

    const doctors = getDB("doctors");
    let finalName = name.startsWith("Dr.") ? name : "Dr. " + name;

    doctors.push({
        id: `DOC-${101 + doctors.length}`,
        name: finalName,
        specialty: spec,
        pin: pin,
        status: "Active"
    });
    saveDB("doctors", doctors);

    document.getElementById("admin-doc-onboard-form").reset();
    alert(`Medical credentials activated for ${finalName}.`);
    renderAdminDashboardLedgers();
}

function updateDoctorLifecycleStatus(docId, newStatus) {
    if (!newStatus) return;
    const doctors = getDB("doctors");
    const idx = doctors.findIndex(d => d.id === docId);
    
    if (idx !== -1) {
        if (newStatus === "Fired") {
            if (confirm(`Warning: Purge directory file for ${doctors[idx].name}?`)) doctors.splice(idx, 1);
        } else {
            doctors[idx].status = newStatus;
        }
        saveDB("doctors", doctors);
        renderAdminDashboardLedgers();
    }
}

