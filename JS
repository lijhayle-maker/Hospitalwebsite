// ==========================================
// DB CORE STORAGE CONTROLLERS
// ==========================================
function getDB(key) {
    const raw = localStorage.getItem(key);
    if (!raw) return [];
    try { 
        return JSON.parse(raw) || []; 
    } catch (e) { 
        console.error("Database read violation.", e);
        return []; 
    }
}

function saveDB(key, arrayData) {
    localStorage.setItem(key, JSON.stringify(arrayData));
}

function verifyDatabaseStateIntegrity() {
    if (!localStorage.getItem("patients")) {
        saveDB("patients", []);
    }
    if (!localStorage.getItem("cash_ledger")) {
        // Seed initial floating capital balance
        saveDB("cash_ledger", [{ type: "In", amount: 25000.00, note: "Initial Treasury Floating Capital Base", date: new Date().toLocaleDateString() }]);
    }
    if (!localStorage.getItem("doctors") || getDB("doctors").length === 0) {
        const initialStaff = [
            { id: "DOC-101", name: "Dr. Abraham", specialty: "Cardiology", pin: "1111", status: "Active" },
            { id: "DOC-102", name: "Dr. Bethlehem", specialty: "Orthopedics", pin: "2222", status: "Active" },
            { id: "DOC-103", name: "Dr. Caleb", specialty: "General Medicine", pin: "3333", status: "Active" },
            { id: "DOC-104", name: "Dr. Danait", specialty: "Pediatrics", pin: "4444", status: "Active" }
        ];
        saveDB("doctors", initialStaff);
    }
}

// Global Lifecycle Bootstrapper
document.addEventListener("DOMContentLoaded", () => {
    verifyDatabaseStateIntegrity();
    refreshGlobalCapacityVisualizers();
    switchView('home-view');

    document.getElementById("advanced-intake-form").addEventListener("submit", processIntakeSubmission);
    document.getElementById("admin-doc-onboard-form").addEventListener("submit", processDoctorOnboardingAction);
    document.getElementById("cash-regulation-form").addEventListener("submit", processManualCashTransaction);

    // Global Key Listener for Enter Key Form Submissions
    document.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
            const activeView = document.querySelector(".view:not(.hidden)");
            if (!activeView) return;

            if (activeView.id === "auth-view") {
                e.preventDefault();
                validateGatewayCredentials();
            }
        }
    });
});

// ==========================================
// VIEW ROUTER MATRIX
// ==========================================
function switchView(viewId) {
    document.querySelectorAll(".view").forEach(el => el.classList.add("hidden"));
    document.getElementById(viewId).classList.remove("hidden");
    
    if (viewId === 'admin-view') renderAdminDashboardLedgers();
    if (viewId === 'doctor-view') renderPhysicianWorkspaceQueue();
    
    refreshGlobalCapacityVisualizers();
}

function clearIntakeForm() {
    document.getElementById("advanced-intake-form").reset();
}

function refreshGlobalCapacityVisualizers() {
    const patients = getDB("patients");
    const activeInpatients = patients.filter(p => !p.discharged).length;
    const MAX_WARDS = 50; // Increased ward count limit
    
    const countLabel = document.getElementById("bed-count-label");
    if (countLabel) {
        countLabel.innerText = `${activeInpatients} / ${MAX_WARDS} Wards Occupied`;
    }
    const pct = Math.min((activeInpatients / MAX_WARDS) * 100, 100);
    const bar = document.getElementById("bed-progress-fill");
    if (bar) bar.style.width = `${pct}%`;
}

// Dynamic Room Allocation Matrix
function getDepartmentRoom(department) {
    const roomMapping = {
        "Cardiology": "Tower A - Room 302 (Cardio-Cath Suite)",
        "Orthopedics": "Tower B - Room 115 (Skeletal Trauma Bay)",
        "Pediatrics": "West Wing - Room 204 (Pediatric Care Zone)",
        "General Medicine": "Main Pavilion - Room 108 (Standard Intake Ward)"
    };
    return roomMapping[department] || "General Triage Zone Box-C";
}

// ==========================================
// CLINICAL INTAKE ROUTING ENGINE
// ==========================================
function processIntakeSubmission(e) {
    e.preventDefault();

    const name = document.getElementById("pt-name").value.trim();
    const relation = document.getElementById("pt-relation").value;
    const age = parseInt(document.getElementById("pt-age").value);
    const sex = document.getElementById("pt-gender").value;
    const phone = document.getElementById("pt-phone").value;
    const symptom = document.getElementById("pt-symptom").value;
    const duration = document.getElementById("pt-duration").value;
    const allergies = document.getElementById("pt-allergies").value.trim() || "No Known Drug Allergies (NKDA)";
    const chronic = document.getElementById("pt-chronic").value;
    const bp = document.getElementById("pt-bp").value;
    const triage = document.getElementById("pt-triage").value;

    const patients = getDB("patients");
    const doctors = getDB("doctors");

    let targetSpecialty = "General Medicine";
    if (symptom === "Chest Pain") targetSpecialty = "Cardiology";
    else if (symptom === "Fracture") targetSpecialty = "Orthopedics";
    else if (symptom === "Pediatric Illness" || age <= 12) targetSpecialty = "Pediatrics";

    let assignedDoc = doctors.find(d => d.specialty === targetSpecialty && d.status === "Active");
    if (!assignedDoc) {
        assignedDoc = doctors.find(d => d.status === "Active") || doctors[0];
    }

    const trackingId = `PT-${1001 + patients.length}`;

    const record = {
        id: trackingId,
        name: name,
        relationContext: relation,
        age: age,
        biologicalSex: sex,
        contactPhone: phone,
        presentingSymptom: symptom,
        symptomDuration: duration,
        declaredAllergies: allergies,
        comorbiditiesHistory: chronic,
        bloodPressureTrend: bp,
        triageSeverityIndex: triage,
        assignedConsultantName: assignedDoc ? assignedDoc.name : "Emergency Pool Specialist",
        assignedConsultantId: assignedDoc ? assignedDoc.id : "DOC-103",
        routedDepartment: assignedDoc ? assignedDoc.specialty : "General Medicine",
        allocatedRoom: getDepartmentRoom(targetSpecialty),
        clinicalInterventionsHistory: ["Initial triage routing verified. Awaiting evaluation parameters."],
        financialAccountBalance: 150.00, // Accumulated accrued processing bill
        discharged: false
    };

    patients.push(record);
    saveDB("patients", patients);

    document.getElementById("advanced-intake-form").reset();
    refreshGlobalCapacityVisualizers();

    alert(`HEALTH RECORD COMPILED\nFile Tracking Key: ${trackingId}\nAssigned Room: ${record.allocatedRoom}`);
}

